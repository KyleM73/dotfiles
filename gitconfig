# Identity and any host-specific routing live in untracked includes, so personal
# and work details are never committed here. The setup script writes
# ~/.gitconfig.local and can add conditional includes for a separate work identity.
[include]
    path = ~/.gitconfig.local

[init]
    defaultBranch = main

[pull]
    rebase = false

[push]
    default = simple
    autoSetupRemote = true

[fetch]
    prune = true

[core]
    editor = vim

[color]
    ui = auto

[alias]
    s = status
    a = add
    aa = add -A
    c = commit -m
    co = checkout
    b = branch
    d = diff
    p = push
    pl = pull
    l = log --oneline --graph --decorate -20
