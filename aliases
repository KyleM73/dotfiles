# Common Aliases
# GNU ls uses --color=auto; BSD ls (stock macOS) uses -G
if ls --color=auto >/dev/null 2>&1; then
    alias ls='ls --color=auto'
else
    alias ls='ls -G'
fi
alias ll='ls -lah'
alias la='ls -A'
alias l='ls -CF'
alias grep='grep --color=auto'
alias df='df -h'
alias du='du -h'
alias c='clear'
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias .....='cd ../../../..'
alias ......='cd ../../../../..'

# Git Aliases
alias gs='git status'
alias ga='git add'
alias gaa='git add -A'
alias gc='git commit -m'
alias gp='git push'
alias gl='git pull'
alias gco='git checkout'
alias gb='git branch'
alias gd='git diff'

# Docker Aliases
alias dps='docker ps'
alias dpsa='docker ps -a'
alias drm='docker rm $(docker ps -a -q)'
alias dimg='docker images'
alias drmi='docker rmi $(docker images -q)'
alias dstart='docker start'
alias dstop='docker stop'
alias dexec='docker exec -it'

# Docker Compose Aliases
alias dcu='docker compose up'
alias dcd='docker compose down'
alias dcb='docker compose build'
alias dcr='docker compose run --rm'
alias dclean='docker compose down --remove-orphans --volumes'

# Conda Aliases
alias ca='conda activate'
alias cdd='conda deactivate'
alias cdda='while [ -n "$CONDA_PREFIX" ]; do conda deactivate; done'

# RC Aliases
alias src='[ -n "$ZSH_VERSION" ] && source ~/.zshrc || source ~/.bashrc'
alias shellrc='[ -n "$ZSH_VERSION" ] && vim ~/.zshrc || vim ~/.bashrc'
alias bashrc='[ -n "$ZSH_VERSION" ] && vim ~/.zshrc || vim ~/.bashrc'
alias zshrc='[ -n "$ZSH_VERSION" ] && vim ~/.zshrc || vim ~/.bashrc'
alias vimrc='vim ~/.vimrc'
alias nvimrc='nvim ~/.config/nvim/init.lua'
alias screenrc='vim ~/.screenrc'
alias gitconfig='vim ~/.gitconfig'
alias zellijrc='${EDITOR:-vim} ~/.config/zellij/config.kdl'
alias yazirc='${EDITOR:-vim} ~/.config/yazi/yazi.toml'

# Neovim / multiplexer shortcuts
alias v='nvim'
alias zj='zellij'

# venv
alias venv="source .venv/bin/activate"
